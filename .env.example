# FreightX Environment Variables Example
# Duplicate this file to .env and configure the variables below.

# 1. Private key used for smart contract deployment on Arc Testnet (DO NOT use mainnet keys!)
# Ensure the account has testnet USDC for gas (since Arc uses USDC as the native gas token).
# Fund your wallet address at https://faucet.circle.com (select Arc Testnet).
PRIVATE_KEY=0xYOUR_TESTNET_PRIVATE_KEY_HERE

# 2. RPC URL for the Arc Testnet chain
# Default public RPC endpoint for Arc Testnet is: https://rpc.testnet.arc.network
ARC_TESTNET_RPC_URL=https://rpc.testnet.arc.network
